name = "nagoya-city-notice-bot"
main = "src/index.ts"
compatibility_date = "2025-01-29"

[observability.logs]
enabled = true

[triggers]
crons =  ["*/1 * * * *"]

[vars]
RSS_URL = "https://www.city.nagoya.jp/news.rss"
MISSKEY_HOST = "jiskey.dev"

[[kv_namespaces]]
binding = "POSTED_ITEMS"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_KV_PREVIEW_NAMESPACE_ID"

[[durable_objects.bindings]]
name = "SYNC_LOCK"
class_name = "SyncLock"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["SyncLock"]
